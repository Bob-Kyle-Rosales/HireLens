@page "/candidates"
@attribute [Authorize(Policy = "RecruiterOrAdmin")]
@using System.ComponentModel.DataAnnotations
@using System.Security.Claims
@using HireLens.Application.DTOs
@using HireLens.Application.Interfaces
@using Microsoft.AspNetCore.Components
@inject ICandidateService CandidateService
@inject IJobPostingService JobPostingService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject ISnackbar Snackbar

<PageTitle>Candidates</PageTitle>

<MudPaper Class="hl-page-hero mb-4">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
        <div>
            <MudText Typo="Typo.h4" Class="hl-page-title">Candidate Management</MudText>
            <MudText Typo="Typo.body1" Class="hl-page-subtitle">
                Upload resumes, track applicants, and keep your candidate pool searchable.
            </MudText>
        </div>
        <MudStack Row="true" Spacing="1">
            <MudChip Class="hl-metric-chip" Variant="Variant.Filled" Color="Color.Primary">@_totalCount candidates</MudChip>
            <MudChip Class="hl-metric-chip" Variant="Variant.Outlined" Color="Color.Info">Resume intake</MudChip>
        </MudStack>
    </MudStack>
</MudPaper>

<MudGrid>
    <MudItem xs="12" lg="4">
        <MudPaper Class="pa-4 hl-panel">
            <MudText Typo="Typo.h6" Class="hl-panel-title">Upload Candidate Resume</MudText>
            <MudDivider Class="my-3" />

            <MudTextField T="string"
                          Label="Full Name"
                          Variant="Variant.Outlined"
                          @bind-Value="_upload.FullName" />

            <MudTextField T="string"
                          Label="Email"
                          Variant="Variant.Outlined"
                          Class="mt-3"
                          @bind-Value="_upload.Email" />

            <MudSelect T="Guid?"
                       Label="Target Job Role"
                       Variant="Variant.Outlined"
                       Class="mt-3"
                       @bind-Value="_upload.JobPostingId">
                <MudSelectItem T="Guid?" Value="@((Guid?)null)">Select job role</MudSelectItem>
                @foreach (var job in _jobs)
                {
                    <MudSelectItem T="Guid?" Value="@job.Id">@job.Title</MudSelectItem>
                }
            </MudSelect>

            <MudPaper Class="pa-3 mt-3 hl-file-box" Outlined="true">
                <MudText Typo="Typo.caption">Resume (.pdf or .txt, max 10 MB)</MudText>
                <InputFile OnChange="HandleFileSelected" class="mt-2" />
                @if (!string.IsNullOrWhiteSpace(_selectedFileName))
                {
                    <MudText Typo="Typo.caption" Class="mt-2 hl-muted">Selected: @_selectedFileName</MudText>
                }
            </MudPaper>

            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       Class="mt-4"
                       Disabled="@_uploading"
                       OnClick="UploadAsync">
                Upload
            </MudButton>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" lg="8">
        <MudPaper Class="pa-4 hl-panel">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                <MudText Typo="Typo.h6" Class="hl-panel-title">Candidates</MudText>
                <MudButton Variant="Variant.Text" Color="Color.Primary" OnClick="ReloadAsync">
                    Refresh
                </MudButton>
            </MudStack>
            <MudStack Row="true" Spacing="1" Class="my-3 hl-toolbar-wrap">
                <MudTextField T="string"
                              Style="flex: 1"
                              Variant="Variant.Outlined"
                              Immediate="true"
                              Placeholder="Search by name, email, file, or category..."
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              Value="@_searchText"
                              ValueChanged="OnSearchChanged" />
                <MudButton Variant="Variant.Outlined"
                           Disabled="@(_loading || !HasActiveFilters)"
                           OnClick="ClearFiltersAsync">
                    Clear
                </MudButton>
            </MudStack>

            <MudTable Items="_candidates" Hover="true" Dense="true" Loading="@_loading" Class="hl-data-table">
                <HeaderContent>
                    <MudTh>Name</MudTh>
                    <MudTh>Email</MudTh>
                    <MudTh>Applied Job</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh>Category</MudTh>
                    <MudTh>Confidence</MudTh>
                    <MudTh>Skills</MudTh>
                    <MudTh>Resume</MudTh>
                    <MudTh>Uploaded</MudTh>
                    <MudTh></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Name">@context.FullName</MudTd>
                    <MudTd DataLabel="Email">@context.Email</MudTd>
                    <MudTd DataLabel="Applied Job">@(context.LatestAppliedJobTitle ?? "-")</MudTd>
                    <MudTd DataLabel="Status">
                        <MudChip Variant="Variant.Outlined" Color="@GetApplicationStatusColor(context.LatestApplicationStatus)">
                            @(context.LatestApplicationStatus ?? "Unassigned")
                        </MudChip>
                    </MudTd>
                    <MudTd DataLabel="Category">@(context.LatestPredictedCategory ?? "N/A")</MudTd>
                    <MudTd DataLabel="Confidence">@FormatConfidence(context.LatestConfidenceScore)</MudTd>
                    <MudTd DataLabel="Skills">
                        <MudText Typo="Typo.caption">@FormatSkillsPreview(context.LatestExtractedSkills)</MudText>
                    </MudTd>
                    <MudTd DataLabel="Resume">@context.ResumeFileName</MudTd>
                    <MudTd DataLabel="Uploaded">@context.CreatedUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</MudTd>
                    <MudTd DataLabel="AI">
                        <MudButton Variant="Variant.Outlined"
                                   Size="Size.Small"
                                   Color="Color.Info"
                                   OnClick="@(() => SelectCandidate(context))">
                            Details
                        </MudButton>
                    </MudTd>
                </RowTemplate>
                <NoRecordsContent>
                    <MudText Typo="Typo.body2">
                        @(HasActiveFilters ? "No candidates match your current search." : "No candidates uploaded yet.")
                    </MudText>
                </NoRecordsContent>
            </MudTable>

            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mt-3">
                <MudText Typo="Typo.caption" Class="hl-muted">
                    Showing page @_pageNumber of @TotalPages (@_totalCount total candidates)
                </MudText>
                <MudStack Row="true" Spacing="1">
                    <MudButton Variant="Variant.Outlined"
                               Size="Size.Small"
                               Disabled="@(_loading || _pageNumber <= 1)"
                               OnClick="PreviousPageAsync">
                        Previous
                    </MudButton>
                    <MudButton Variant="Variant.Outlined"
                               Size="Size.Small"
                               Disabled="@(_loading || _pageNumber >= TotalPages)"
                               OnClick="NextPageAsync">
                        Next
                    </MudButton>
                </MudStack>
            </MudStack>

            <MudDivider Class="my-3" />

            @if (_selectedCandidate is null)
            {
                <MudText Typo="Typo.body2" Class="hl-muted">
                    Select a candidate row to inspect AI outputs (category, confidence, extracted skills).
                </MudText>
            }
            else
            {
                <MudText Typo="Typo.subtitle1" Class="hl-panel-title">AI Details: @_selectedCandidate.FullName</MudText>
                <MudText Typo="Typo.caption" Class="hl-muted">
                    Last analyzed: @FormatAnalyzedUtc(_selectedCandidate.LatestAnalyzedUtc)
                </MudText>

                <MudStack Row="true" Spacing="1" Class="mt-2">
                    <MudChip Variant="Variant.Outlined" Color="Color.Info">
                        Category: @(_selectedCandidate.LatestPredictedCategory ?? "N/A")
                    </MudChip>
                    <MudChip Variant="Variant.Outlined" Color="@GetConfidenceColor(_selectedCandidate.LatestConfidenceScore)">
                        Confidence: @FormatConfidence(_selectedCandidate.LatestConfidenceScore)
                    </MudChip>
                </MudStack>

                <MudText Typo="Typo.subtitle2" Class="mt-3">Extracted Skills</MudText>
                <MudChipSet Class="mt-1">
                    @foreach (var skill in GetSkillsOrPlaceholder(_selectedCandidate.LatestExtractedSkills))
                    {
                        <MudChip Variant="Variant.Outlined" Color="Color.Success">@skill</MudChip>
                    }
                </MudChipSet>
            }
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    private const long MaxResumeSizeBytes = 10 * 1024 * 1024;
    private const int DefaultPageSize = 10;

    [SupplyParameterFromQuery(Name = "jobId")]
    public Guid? JobId { get; set; }

    private readonly UploadFormModel _upload = new();
    private List<CandidateDto> _candidates = [];
    private List<JobPostingDto> _jobs = [];
    private CandidateDto? _selectedCandidate;
    private IBrowserFile? _selectedFile;
    private string _selectedFileName = string.Empty;
    private bool _loading;
    private bool _uploading;
    private string _searchText = string.Empty;
    private int _pageNumber = 1;
    private int _totalCount;

    private int TotalPages => Math.Max(1, (int)Math.Ceiling(_totalCount / (double)DefaultPageSize));
    private bool HasActiveFilters => !string.IsNullOrWhiteSpace(_searchText);

    protected override async Task OnInitializedAsync()
    {
        await LoadJobsAsync();
        ApplySelectedJobFromQuery();
        await ReloadAsync();
    }

    protected override void OnParametersSet()
    {
        ApplySelectedJobFromQuery();
    }

    private async Task LoadJobsAsync()
    {
        try
        {
            _jobs = (await JobPostingService.GetAllAsync())
                .OrderBy(x => x.Title)
                .ToList();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load jobs: {ex.Message}", Severity.Error);
        }
    }

    private void ApplySelectedJobFromQuery()
    {
        if (JobId is not null && _jobs.Any(x => x.Id == JobId.Value))
        {
            _upload.JobPostingId = JobId.Value;
        }
    }

    private async Task ReloadAsync()
    {
        _loading = true;
        try
        {
            var page = await CandidateService.GetPagedAsync(_pageNumber, DefaultPageSize, _searchText);
            _candidates = page.Items.ToList();
            _totalCount = page.TotalCount;
            _selectedCandidate = _selectedCandidate is null
                ? _candidates.FirstOrDefault()
                : _candidates.FirstOrDefault(x => x.Id == _selectedCandidate.Id) ?? _candidates.FirstOrDefault();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load candidates: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OnSearchChanged(string value)
    {
        _searchText = value;
        _pageNumber = 1;
        await ReloadAsync();
    }

    private async Task ClearFiltersAsync()
    {
        if (!HasActiveFilters)
        {
            return;
        }

        _searchText = string.Empty;
        _pageNumber = 1;
        await ReloadAsync();
    }

    private async Task PreviousPageAsync()
    {
        if (_pageNumber <= 1)
        {
            return;
        }

        _pageNumber--;
        await ReloadAsync();
    }

    private async Task NextPageAsync()
    {
        if (_pageNumber >= TotalPages)
        {
            return;
        }

        _pageNumber++;
        await ReloadAsync();
    }

    private void HandleFileSelected(InputFileChangeEventArgs args)
    {
        _selectedFile = args.File;
        _selectedFileName = _selectedFile.Name;
    }

    private async Task UploadAsync()
    {
        if (_uploading)
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(_upload.FullName) || string.IsNullOrWhiteSpace(_upload.Email))
        {
            Snackbar.Add("Full Name and Email are required.", Severity.Warning);
            return;
        }

        if (_upload.JobPostingId is null)
        {
            Snackbar.Add("Please select a target job role.", Severity.Warning);
            return;
        }

        if (_selectedFile is null)
        {
            Snackbar.Add("Please select a resume file.", Severity.Warning);
            return;
        }

        if (_selectedFile.Size > MaxResumeSizeBytes)
        {
            Snackbar.Add("Resume exceeds 10 MB limit.", Severity.Warning);
            return;
        }

        _uploading = true;

        try
        {
            await using var stream = _selectedFile.OpenReadStream(MaxResumeSizeBytes);
            await using var memoryStream = new MemoryStream();
            await stream.CopyToAsync(memoryStream);

            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var userId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? "system";

            var request = new CandidateUploadRequest
            {
                FullName = _upload.FullName.Trim(),
                Email = _upload.Email.Trim(),
                ResumeFileName = _selectedFile.Name,
                ResumeContentType = string.IsNullOrWhiteSpace(_selectedFile.ContentType)
                    ? "application/octet-stream"
                    : _selectedFile.ContentType,
                ResumeContent = memoryStream.ToArray(),
                JobPostingId = _upload.JobPostingId.Value,
                UploadedByUserId = userId
            };

            await CandidateService.UploadAsync(request);
            Snackbar.Add("Candidate uploaded.", Severity.Success);
            ResetUploadForm();
            _pageNumber = 1;
            await ReloadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Upload failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _uploading = false;
        }
    }

    private void ResetUploadForm()
    {
        _upload.FullName = string.Empty;
        _upload.Email = string.Empty;
        _upload.JobPostingId = JobId is not null && _jobs.Any(x => x.Id == JobId.Value) ? JobId : null;
        _selectedFile = null;
        _selectedFileName = string.Empty;
    }

    private void SelectCandidate(CandidateDto candidate)
    {
        _selectedCandidate = candidate;
    }

    private static string FormatConfidence(double? confidence)
    {
        return confidence is null ? "N/A" : confidence.Value.ToString("P0");
    }

    private static Color GetConfidenceColor(double? confidence)
    {
        if (confidence is null)
        {
            return Color.Default;
        }

        if (confidence.Value >= 0.8)
        {
            return Color.Success;
        }

        if (confidence.Value >= 0.6)
        {
            return Color.Warning;
        }

        return Color.Error;
    }

    private static string FormatSkillsPreview(IReadOnlyList<string> skills)
    {
        if (skills.Count == 0)
        {
            return "No extracted skills";
        }

        var preview = skills.Take(3).ToList();
        return preview.Count == skills.Count
            ? string.Join(", ", preview)
            : $"{string.Join(", ", preview)} (+{skills.Count - preview.Count} more)";
    }

    private static string FormatAnalyzedUtc(DateTime? analyzedUtc)
    {
        return analyzedUtc is null
            ? "No analysis data"
            : analyzedUtc.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm");
    }

    private static IReadOnlyList<string> GetSkillsOrPlaceholder(IReadOnlyList<string> skills)
    {
        return skills.Count == 0 ? ["None"] : skills;
    }

    private static Color GetApplicationStatusColor(string? status)
    {
        return status switch
        {
            "Scored" => Color.Success,
            "Analyzed" => Color.Info,
            "Failed" => Color.Error,
            _ => Color.Default
        };
    }

    private sealed class UploadFormModel
    {
        [Required]
        public string FullName { get; set; } = string.Empty;

        [Required]
        public string Email { get; set; } = string.Empty;

        public Guid? JobPostingId { get; set; }
    }
}
