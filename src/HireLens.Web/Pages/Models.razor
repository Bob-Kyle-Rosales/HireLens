@page "/models"
@attribute [Authorize(Policy = "AdminOnly")]
@using HireLens.Application.Interfaces
@using HireLens.Web.Services
@inject IDashboardReadService DashboardReadService
@inject IModelVersionService ModelVersionService
@inject IResumeAnalysisService ResumeAnalysisService
@inject ISnackbar Snackbar

<PageTitle>Models</PageTitle>

<MudPaper Class="hl-page-hero mb-4">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
        <div>
            <MudText Typo="Typo.h4" Class="hl-page-title">Model Registry</MudText>
            <MudText Typo="Typo.body1" Class="hl-page-subtitle">
                Track model versions, accuracy snapshots, and active deployment status.
            </MudText>
        </div>
        <MudStack Row="true" Spacing="1">
            <MudChip Class="hl-metric-chip" Variant="Variant.Filled" Color="Color.Primary">@_rows.Count versions</MudChip>
            <MudChip Class="hl-metric-chip" Variant="Variant.Outlined" Color="Color.Success">@_rows.Count(x => x.IsActive) active</MudChip>
        </MudStack>
    </MudStack>
</MudPaper>

<MudPaper Class="pa-4 hl-panel">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
        <MudText Typo="Typo.h6" Class="hl-panel-title">Saved Models</MudText>
        <MudStack Row="true" Spacing="1">
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Primary"
                       Disabled="@(_loading || _training || _reanalyzing || _activatingModelId is not null)"
                       OnClick="TrainResumeCategoryAsync">
                @(_training ? "Training..." : "Train Resume Model")
            </MudButton>
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Info"
                       Disabled="@(_loading || _training || _reanalyzing || _activatingModelId is not null)"
                       OnClick="ReanalyzeAllCandidatesAsync">
                @(_reanalyzing ? "Re-analyzing..." : "Re-analyze Candidates")
            </MudButton>
            <MudButton Variant="Variant.Text"
                       Color="Color.Primary"
                       Disabled="@(_loading || _training || _reanalyzing || _activatingModelId is not null)"
                       OnClick="LoadAsync">
                Refresh
            </MudButton>
        </MudStack>
    </MudStack>

    <MudDivider Class="my-3" />

    <MudTable Items="_rows" Hover="true" Dense="true" Loading="@_loading" Class="hl-data-table">
        <HeaderContent>
            <MudTh>Model Type</MudTh>
            <MudTh>Version</MudTh>
            <MudTh>Accuracy</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Trained</MudTh>
            <MudTh>Path</MudTh>
            <MudTh>Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Model Type">@context.ModelType</MudTd>
            <MudTd DataLabel="Version">@context.Version</MudTd>
            <MudTd DataLabel="Accuracy">@context.Accuracy.ToString("P2")</MudTd>
            <MudTd DataLabel="Status">
                <MudChip Variant="Variant.Outlined" Color="@(context.IsActive ? Color.Success : Color.Default)">
                    @(context.IsActive ? "Active" : "Inactive")
                </MudChip>
            </MudTd>
            <MudTd DataLabel="Trained">@context.TrainedUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</MudTd>
            <MudTd DataLabel="Path">
                <MudTooltip Text="@context.StoragePath">
                    <MudText Typo="Typo.caption">@Truncate(context.StoragePath, 32)</MudText>
                </MudTooltip>
            </MudTd>
            <MudTd DataLabel="Actions">
                <MudButton Variant="Variant.Outlined"
                           Size="Size.Small"
                           Color="Color.Success"
                           Disabled="@(_loading || _training || _reanalyzing || _activatingModelId is not null || context.IsActive)"
                           OnClick="@(() => ActivateModelAsync(context.Id))">
                    @(_activatingModelId == context.Id ? "Activating..." : "Set Active")
                </MudButton>
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText Typo="Typo.body2">No model versions saved yet.</MudText>
        </NoRecordsContent>
    </MudTable>
</MudPaper>

@code {
    private List<ModelVersionRowDto> _rows = [];
    private bool _loading;
    private bool _training;
    private bool _reanalyzing;
    private Guid? _activatingModelId;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            _rows = (await DashboardReadService.GetModelVersionsAsync()).ToList();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load model versions: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task TrainResumeCategoryAsync()
    {
        if (_training || _loading || _reanalyzing || _activatingModelId is not null)
        {
            return;
        }

        _training = true;

        try
        {
            var trained = await ModelVersionService.TrainResumeCategoryModelAsync();
            Snackbar.Add(
                $"Model trained: {trained.Version} ({trained.Accuracy:P1} accuracy).",
                Severity.Success);

            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Model training failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _training = false;
        }
    }

    private async Task ReanalyzeAllCandidatesAsync()
    {
        if (_reanalyzing || _loading || _training || _activatingModelId is not null)
        {
            return;
        }

        _reanalyzing = true;

        try
        {
            var analyzedCount = await ResumeAnalysisService.AnalyzeAllCandidatesAsync();
            Snackbar.Add($"Re-analysis complete: {analyzedCount} candidate(s) processed.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Re-analysis failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _reanalyzing = false;
        }
    }

    private async Task ActivateModelAsync(Guid modelVersionId)
    {
        if (_loading || _training || _reanalyzing || _activatingModelId is not null)
        {
            return;
        }

        _activatingModelId = modelVersionId;

        try
        {
            var activated = await ModelVersionService.SetActiveAsync(modelVersionId);
            if (!activated)
            {
                Snackbar.Add("Model version not found.", Severity.Warning);
                return;
            }

            Snackbar.Add("Model activated.", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Activation failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _activatingModelId = null;
        }
    }

    private static string Truncate(string text, int maxChars)
    {
        if (string.IsNullOrWhiteSpace(text) || text.Length <= maxChars)
        {
            return text;
        }

        return $"{text[..maxChars]}...";
    }
}
