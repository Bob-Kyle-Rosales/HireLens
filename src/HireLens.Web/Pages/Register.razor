@page "/register"
@attribute [AllowAnonymous]
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.WebUtilities
@inject NavigationManager NavigationManager

<PageTitle>Create Account</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-8">
    <MudPaper Class="pa-6 hl-panel hl-auth-panel">
        <MudText Typo="Typo.h5" Class="hl-page-title">Create Account</MudText>
        <MudText Typo="Typo.body2" Class="hl-page-subtitle mb-4">
            Register a recruiter account for this workspace.
        </MudText>

        @if (!string.IsNullOrWhiteSpace(_errorMessage))
        {
            <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Class="mb-3">
                @_errorMessage
            </MudAlert>
        }

        <form method="post" action="/auth/register" class="hl-auth-form">
            <label class="hl-auth-label" for="hl-register-email">Email</label>
            <input id="hl-register-email"
                   class="hl-auth-input"
                   type="email"
                   name="Email"
                   required
                   autocomplete="username"
                   value="@_email" />

            <label class="hl-auth-label mt-3" for="hl-register-password">Password</label>
            <input id="hl-register-password"
                   class="hl-auth-input"
                   type="password"
                   name="Password"
                   required
                   autocomplete="new-password" />

            <label class="hl-auth-label mt-3" for="hl-register-confirm">Confirm Password</label>
            <input id="hl-register-confirm"
                   class="hl-auth-input"
                   type="password"
                   name="ConfirmPassword"
                   required
                   autocomplete="new-password" />

            <input type="hidden" name="ReturnUrl" value="@_returnUrl" />

            <button type="submit" class="hl-auth-button mt-4">Create Account</button>
        </form>

        <MudText Typo="Typo.body2" Class="mt-4 hl-muted">
            Already have an account?
            <MudLink Href="@GetLoginHref()">Sign in</MudLink>
        </MudText>
    </MudPaper>
</MudContainer>

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthenticationStateTask { get; set; }

    private string _email = string.Empty;
    private string _returnUrl = "/";
    private string _errorMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        if (AuthenticationStateTask is not null)
        {
            var authState = await AuthenticationStateTask;
            if (authState.User.Identity?.IsAuthenticated ?? false)
            {
                NavigationManager.NavigateTo("/", forceLoad: true);
                return;
            }
        }

        var uri = NavigationManager.ToAbsoluteUri(NavigationManager.Uri);
        var query = QueryHelpers.ParseQuery(uri.Query);

        _email = query.TryGetValue("email", out var email) ? email.ToString() : string.Empty;
        _errorMessage = query.TryGetValue("error", out var error) ? error.ToString() : string.Empty;

        var requestedReturnUrl = query.TryGetValue("returnUrl", out var returnUrl)
            ? returnUrl.ToString()
            : "/";

        _returnUrl = GetSafeLocalReturnUrl(requestedReturnUrl);
    }

    private string GetLoginHref()
    {
        return $"/login?returnUrl={Uri.EscapeDataString(_returnUrl)}";
    }

    private static string GetSafeLocalReturnUrl(string? returnUrl)
    {
        if (string.IsNullOrWhiteSpace(returnUrl))
        {
            return "/";
        }

        return returnUrl.StartsWith("/", StringComparison.Ordinal) && !returnUrl.StartsWith("//", StringComparison.Ordinal)
            ? returnUrl
            : "/";
    }
}
