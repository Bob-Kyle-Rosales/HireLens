@inject NavigationManager NavigationManager

@code {
    protected override void OnInitialized()
    {
        var relative = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        if (relative.StartsWith("access-denied", StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        var returnUrl = string.IsNullOrWhiteSpace(relative) ? "/" : $"/{relative}";
        var target = $"/access-denied?returnUrl={Uri.EscapeDataString(returnUrl)}";
        NavigationManager.NavigateTo(target, forceLoad: true, replace: true);
    }
}
