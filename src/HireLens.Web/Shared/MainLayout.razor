@inherits LayoutComponentBase

<MudThemeProvider Theme="@_theme" />
<MudBreakpointProvider OnBreakpointChanged="HandleBreakpointChanged" />

<MudLayout Class="hl-shell">
    <MudAppBar Elevation="0" Dense="true" Class="hl-appbar">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@ToggleDrawer" />
        <MudAvatar Icon="@Icons.Material.Filled.Psychology" Color="Color.Primary" Variant="Variant.Filled" Class="mr-2 hl-brand-icon" />
        <MudStack Spacing="0">
            <MudText Typo="Typo.h6" Class="hl-brand-title">HireLens</MudText>
            <MudText Typo="Typo.caption" Class="hl-brand-subtitle">Recruiting workspace</MudText>
        </MudStack>
        <MudSpacer />
        <MudChip Variant="Variant.Outlined" Color="Color.Info" Size="Size.Small" Class="hl-status-chip">
            Preview
        </MudChip>
        <AuthorizeView>
            <Authorized>
                <form method="post" action="/auth/logout" class="hl-inline-form">
                    <input type="hidden" name="ReturnUrl" value="/" />
                    <MudButton Variant="Variant.Text"
                               Color="Color.Inherit"
                               Size="Size.Small"
                               ButtonType="ButtonType.Submit">
                        Sign Out
                    </MudButton>
                </form>
            </Authorized>
            <NotAuthorized>
                <MudButton Variant="Variant.Text"
                           Color="Color.Inherit"
                           Size="Size.Small"
                           Href="/login">
                    Sign In
                </MudButton>
            </NotAuthorized>
        </AuthorizeView>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" Variant="DrawerVariant.Responsive" Breakpoint="Breakpoint.Md" Elevation="1" Class="hl-drawer">
        <NavMenu OnNavigate="HandleNavigation" />
    </MudDrawer>

    <MudMainContent Class="hl-main">
        @Body
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;

    private static readonly MudTheme _theme = new()
    {
        Palette = new Palette
        {
            Primary = "#0f766e",
            Secondary = "#d97706",
            Tertiary = "#2563eb",
            Background = "#f3f7f6",
            AppbarBackground = "#0f172a",
            AppbarText = "#f8fafc",
            DrawerBackground = "#ffffff",
            Surface = "#ffffff",
            TextPrimary = "#1f2937",
            TextSecondary = "#4b5563"
        },
        LayoutProperties = new LayoutProperties
        {
            DefaultBorderRadius = "12px"
        },
        Typography = new Typography
        {
            Default = new Default
            {
                FontFamily = new[] { "Manrope", "Segoe UI", "sans-serif" }
            }
        }
    };

    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }

    private void HandleBreakpointChanged(Breakpoint breakpoint)
    {
        _isMobile = breakpoint is Breakpoint.Xs or Breakpoint.Sm;
    }

    private void HandleNavigation()
    {
        if (_isMobile)
        {
            _drawerOpen = false;
        }
    }

    private bool _isMobile;
}
