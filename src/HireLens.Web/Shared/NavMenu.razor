<MudNavMenu Class="hl-nav-menu pa-4">
    <MudPaper Class="hl-nav-brand pa-3 mb-4">
        <MudText Typo="Typo.caption" Class="hl-nav-kicker">Workspace</MudText>
        <MudText Typo="Typo.subtitle1" Class="hl-nav-title">Talent Pipeline</MudText>
        <MudText Typo="Typo.caption" Class="hl-nav-caption">Manage jobs, resumes, scoring</MudText>
    </MudPaper>

    <AuthorizeView>
        <Authorized>
            <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">
                Dashboard
            </MudNavLink>
            <MudNavLink Href="/jobs" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.WorkOutline">
                Jobs
            </MudNavLink>
            <MudNavLink Href="/candidates" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.PeopleOutline">
                Candidates
            </MudNavLink>
            <MudNavLink Href="/matches" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.BarChart">
                Matches
            </MudNavLink>
            <AuthorizeView Policy="AdminOnly" Context="adminAuth">
                <MudNavLink Href="/models" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.AutoGraph">
                    Models
                </MudNavLink>
            </AuthorizeView>
        </Authorized>
        <NotAuthorized>
            <MudNavLink Href="/login" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Login">
                Sign In
            </MudNavLink>
        </NotAuthorized>
    </AuthorizeView>
</MudNavMenu>
